---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Links – BEWEGGRUND."
  description="Weiterführende Links zu Ausbildungsorten, Weiterbildungen, Medizinischen Qualitätsregistern und Berufskollegen der Praxis BEWEGGRUND."
>

  <!-- ─── Page Header ───────────────────────── -->
  <div class="page-header">
    <div class="container">
      <span class="eyebrow">BEWEGGRUND.</span>
      <h1>Links</h1>
      <span class="rule rule--center"></span>
    </div>
  </div>

  <!-- ─── Content ──────────────────────────── -->
  <section style="padding: var(--s16) 0 var(--s24);">
    <div class="container">
      <div class="links-grid">

        <!-- Ausbildungsorte -->
        <div class="links-section">
          <span class="links-section-label">Meine Ausbildungsorte</span>
          <ul class="links-list">
            <li>
              <a href="https://www.paramed.ch" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Paramed</span>
                <span class="link-href">www.paramed.ch</span>
              </a>
            </li>
            <li>
              <a href="https://www.college-sutherland.de" target="_blank" rel="noopener noreferrer">
                <span class="link-name">College Sutherland</span>
                <span class="link-href">www.college-sutherland.de</span>
              </a>
            </li>
            <li>
              <a href="https://www.sgmf.ch" target="_blank" rel="noopener noreferrer">
                <span class="link-name">SGMF</span>
                <span class="link-href">www.sgmf.ch</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Weiterbildungsorte -->
        <div class="links-section">
          <span class="links-section-label">Meine Weiterbildungsorte</span>
          <ul class="links-list">
            <li>
              <a href="https://www.mitha-moeckel.com" target="_blank" rel="noopener noreferrer">
                <span class="link-name">mitha + möckel Postgraduate Fortbildung Osteopathie</span>
                <span class="link-href">www.mitha-moeckel.com</span>
              </a>
            </li>
            <li>
              <a href="http://www.mithasonntag.de" target="_blank" rel="noopener noreferrer">
                <span class="link-name">mitha + Sonntag Postgraduate Fortbildungen in Osteopathie</span>
                <span class="link-href">www.mithasonntag.de</span>
              </a>
            </li>
            <li>
              <a href="http://www.scco.ac" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Sutherland Cranial College of Osteopathy</span>
                <span class="link-href">www.scco.ac</span>
              </a>
            </li>
            <li>
              <a href="https://www.qualitative-visceral-osteopathy.com" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Qualitative viszerale Osteopathie</span>
                <span class="link-href">www.qualitative-visceral-osteopathy.com</span>
              </a>
            </li>
            <li>
              <a href="https://www.paramed.ch/akademie/" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Akademie der Paramed</span>
                <span class="link-href">www.paramed.ch/akademie/</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Medizinische Qualitätsregister -->
        <div class="links-section">
          <span class="links-section-label">Medizinische Qualitätsregister</span>
          <ul class="links-list">
            <li>
              <a href="https://www.emr.ch" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Erfahrungs Medizinisches Register</span>
                <span class="link-href">www.emr.ch</span>
              </a>
            </li>
            <li>
              <a href="https://www.asca.ch" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Schweizerische Stiftung für Komplementärmedizin</span>
                <span class="link-href">www.asca.ch</span>
              </a>
            </li>
            <li>
              <a href="https://www.stiftung-sne.ch" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Stiftung für Naturheilkunde und Erfahrungsmedizin</span>
                <span class="link-href">www.stiftung-sne.ch</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Berufskollegen -->
        <div class="links-section">
          <span class="links-section-label">Berufskollegen / Praxen</span>
          <ul class="links-list">
            <li>
              <a href="https://www.praxis-beweggrund.ch" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Praxis Beweggrund</span>
                <span class="link-href">www.praxis-beweggrund.ch</span>
              </a>
            </li>
            <li>
              <a href="https://www.mueller-osteopathie.ch" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Mueller Osteopathie</span>
                <span class="link-href">www.mueller-osteopathie.ch</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Informationen -->
        <div class="links-section links-section--video">
          <span class="links-section-label">Informationen / Interessantes</span>
          <ul class="links-list">
            <li>
              <a href="https://www.fasciaresearch.de" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Fascia Research Group der Uni Ulm</span>
                <span class="link-href">www.fasciaresearch.de</span>
              </a>
            </li>
            <li>
              <a href="https://www.wdr.de/tv/quarks/sendungsbeitraege/2007/0206/004_faszien.jsp" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Thema Faszien in der Sendung „Quarks &amp; Co"</span>
                <span class="link-href">zum Video-Beitrag</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Freunde -->
        <div class="links-section">
          <span class="links-section-label">Freunde</span>
          <ul class="links-list">
            <li>
              <a href="https://www.wortbild-vieli.ch" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Wortbild Vieli</span>
                <span class="link-href">www.wortbild-vieli.ch</span>
              </a>
            </li>
            <li>
              <a href="https://www.cmsbox.com" target="_blank" rel="noopener noreferrer">
                <span class="link-name">cmsbox</span>
                <span class="link-href">www.cmsbox.com</span>
              </a>
            </li>
            <li>
              <a href="https://www.stefanschlumpf.com" target="_blank" rel="noopener noreferrer">
                <span class="link-name">Stefan Schlumpf</span>
                <span class="link-href">www.stefanschlumpf.com</span>
              </a>
            </li>
            <li>
              <a href="https://www.photo.li" target="_blank" rel="noopener noreferrer">
                <span class="link-name">photo.li</span>
                <span class="link-href">www.photo.li</span>
              </a>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
